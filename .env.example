# Copy file này thành .env.local rồi điền giá trị thực

# Supabase — lấy tại Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Web3 — chạy Ganache trên máy, deploy contract, lấy dia chi
NEXT_PUBLIC_CHAIN_ID=1337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:7545
NEXT_PUBLIC_ESCROW_ADDRESS=<dia-chi-contract-sau-khi-deploy>
RPC_URL=http://127.0.0.1:7545
